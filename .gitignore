# Environment and secrets
.env
.env.local
.env.production
.env.*.local
*.pem
*.key
credentials.json
secrets.json

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Claude Code runtime (do not version these — they are session-specific)
.claude/projects/
.claude/sessions/
.claude/statsig/
.claude/todos/

# Local telemetry and generated output — never commit
.claude/context/telemetry/
.claude/context/retros/
.claude/context/benchmarks/
.claude/context/canary/
.claude/context/security-reports/
.claude/context/design/

# Session handoff — overwritten each session, personal to the user
.claude/context/handoff.md

# Stop hook guard markers -- transient session state, never commit
.claude/context/.wrapup-done
.claude/context/.review-done
# Stop hook opt-in flags -- personal preference, keep local
.claude/context/.wrap-guard
.claude/context/.review-gate

# Ember gate — ember-due is a transient flag, never commit
# ember.lock and ember.count ARE tracked (shipped initialized so fresh clones
# start the gate timer at install time, not at Unix epoch)
.claude/context/ember-due
.claude/context/kairos.lock
.claude/context/kairos.count
.claude/context/kairos-due

# Attribution log — local audit trail, not project state
.claude/attribution.jsonl

# User context is personal — never commit populated user.md
# user.md.template is tracked; user.md is local-only
.claude/context/user.md

# Node.js dependencies
node_modules/

# Generated from settings.template.json by install.sh -- machine-specific, never commit
.claude/settings.json

# Session artifacts and development files (do not commit)
SESSION_SUMMARY.md
refining_anthropic.md
test_phase*.sh
.claude/settings.local.json

# External skill repos — cloned locally by /install, never committed
.claude/skills/ui-ux-pro-max-skill/
.claude/skills/.venv/

# Scoring rubric -- deployer-managed, never committed
scripts/scoring/rubric.yaml

# MCP server dependencies — installed locally, never committed
mcp-servers/*/node_modules/
mcp-servers/*/.env

# Node.js dependencies
node_modules/
