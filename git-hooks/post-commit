#!/usr/bin/env bash
# post-commit hook — auto version bump and changelog on conventional commits.
#
# Install: cp git-hooks/post-commit .git/hooks/post-commit && chmod +x .git/hooks/post-commit
#
# Reads the conventional commit prefix of the latest commit and bumps the
# version in package.json (if present) accordingly:
#   feat!: or fix!:  → major bump
#   feat:            → minor bump
#   fix: / chore: / refactor: / docs: / test: → patch bump
#
# Loop guard: skips if the current commit message starts with "chore: bump v"
# to prevent recursive triggering.

set -euo pipefail

COMMIT_MSG="$(git log -1 --pretty=%s)"

# Loop guard — do not re-trigger on version bump commits
if [[ "$COMMIT_MSG" == chore:\ bump\ v* ]]; then
  exit 0
fi

# Only act on conventional commits
if [[ ! "$COMMIT_MSG" =~ ^(feat|fix|refactor|docs|test|chore|perf)(\(.+\))?(!)?:\ .+ ]]; then
  exit 0
fi

# Determine bump type
BREAKING=false
if [[ "$COMMIT_MSG" =~ ^(feat|fix)(\(.+\))?!:\ .+ ]]; then
  BREAKING=true
fi

if $BREAKING; then
  BUMP="major"
elif [[ "$COMMIT_MSG" =~ ^feat(\(.+\))?:\ .+ ]]; then
  BUMP="minor"
else
  BUMP="patch"
fi

# Only bump if package.json exists
if [ ! -f "package.json" ]; then
  exit 0
fi

# Get current version
CURRENT_VERSION="$(node -p "require('./package.json').version" 2>/dev/null || echo "")"
if [ -z "$CURRENT_VERSION" ]; then
  exit 0
fi

# Compute new version
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"
case "$BUMP" in
  major) MAJOR=$((MAJOR + 1)); MINOR=0; PATCH=0 ;;
  minor) MINOR=$((MINOR + 1)); PATCH=0 ;;
  patch) PATCH=$((PATCH + 1)) ;;
esac
NEW_VERSION="$MAJOR.$MINOR.$PATCH"

# Update package.json
node -e "
  const fs = require('fs');
  const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
  pkg.version = '$NEW_VERSION';
  fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
"

# Append to CHANGELOG.md
CHANGELOG_ENTRY="## v$NEW_VERSION — $(date +%Y-%m-%d)\n\n- $COMMIT_MSG\n"
if [ -f "CHANGELOG.md" ]; then
  # Insert after the first line (title)
  FIRST_LINE="$(head -1 CHANGELOG.md)"
  REST="$(tail -n +2 CHANGELOG.md)"
  printf "%s\n\n%b\n%s" "$FIRST_LINE" "$CHANGELOG_ENTRY" "$REST" > CHANGELOG.md
else
  printf "# Changelog\n\n%b" "$CHANGELOG_ENTRY" > CHANGELOG.md
fi

# Stage and commit the bump
git add package.json CHANGELOG.md
git commit -m "chore: bump v$NEW_VERSION

Auto-generated by post-commit hook from: $COMMIT_MSG

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>"

echo "[post-commit] Bumped version $CURRENT_VERSION → $NEW_VERSION ($BUMP)"
